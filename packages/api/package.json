{
  "private": true,
  "name": "@petboarding/api",
  "productName": "Petboarding",
  "version": "0.1.0",
  "description": "Petboarding API",
  "license": "ELv2",
  "author": "simsustech",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts"
    },
    "./zod": {
      "import": "./src/zod/index.ts",
      "types": "./src/zod/index.ts"
    },
    "./trpc": {
      "types": "./src/trpc/index.ts"
    },
    "./types": {
      "import": "./src/kysely/types.ts",
      "types": "./src/kysely/types.ts"
    }
  },
  "files": [
    "dist/",
    "vitrify.config.ts"
  ],
  "scripts": {
    "serve": "node ./dist/server/server.mjs",
    "dev": "run-s docker-compose start:dev-server ",
    "build": "run-s build:api build:migrations seed:fake:generate minify:fastify",
    "build:migrations": "tsc -p tsconfig.migrations.json",
    "build:api": "vitrify build -m fastify",
    "minify:csr": "vitrify minify ./dist/csr",
    "minify:ssr:server": "vitrify minify ./dist/ssr/server",
    "minify:ssr:client": "vitrify minify ./dist/ssr/client",
    "minify:ssg": "vitrify minify ./dist/static",
    "minify:fastify": "vitrify minify ./dist/server",
    "test": "vitrify test",
    "test:e2e": "playwright test",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "migrate:latest": "node ./dist/migrate.js",
    "seed:fake:generate": "node ./dist/seeds/fake/writeData.js",
    "seed:fake": "node ./dist/seeds/fake.js",
    "seed:test": "node ./dist/seeds/test.js",
    "seed:data": "node ./dist/seeds/data.js",
    "start": "run-s migrate:latest serve",
    "start:dev-server": "NODE_TLS_REJECT_UNAUTHORIZED=0 vitrify dev -m fastify --port 3000",
    "docker-compose": "node ./docker-compose.dev.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/middie": "9.3.2",
    "@fastify/one-line-logger": "^2.1.0",
    "@fastify/static": "9.1.3",
    "@modular-api/api": "^0.6.21",
    "@modular-api/fastify-checkout": "^0.5.10",
    "@modular-api/fastify-oidc": "^0.9.18",
    "@petboarding/app": "workspace:*",
    "@petboarding/tools": "workspace:*",
    "@pinia/colada": "1.2.0",
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@vitrify/tools": "^0.5.0",
    "bcryptjs": "^3.0.3",
    "compress-tag": "^3.0.0",
    "date-fns": "^4.1.0",
    "date-holidays": "^3.27.0",
    "fastify": "^5.8.5",
    "handlebars": "^4.7.9",
    "kysely": "^0.28.16",
    "npm-run-all": "^4.1.5",
    "otplib": "^13.4.0",
    "pg": "^8.20.0",
    "pg-boss": "^12.16.0",
    "pinia": "^3.0.4",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@iconify-json/flagpack": "^1.2.7",
    "@iconify-json/mdi": "^1.2.3",
    "@playwright/test": "1.59.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/oidc-provider": "^9.5.0",
    "@types/pg": "^8.20.0",
    "@unocss/preset-icons": "^66.6.8",
    "@unocss/preset-wind3": "^66.6.8",
    "@vitejs/plugin-vue": "6.0.6",
    "beasties": "^0.4.2",
    "devcert": "1.2.3",
    "docker-compose": "^1.4.2",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "10.9.0",
    "kysely-codegen": "^0.20.0",
    "oidc-provider": "^9.8.2",
    "openid-client": "^6.8.3",
    "prettier": "^3.8.3",
    "quasar": "2.19.3",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.0",
    "unocss": "^66.6.8",
    "unocss-preset-quasar": "^0.2.13",
    "vite": "8.0.10",
    "vitrify": "^0.26.1",
    "vue": "3.5.33",
    "vue-eslint-parser": "^10.4.0",
    "vue-router": "5.0.6"
  },
  "dependenciesMeta": {
    "@modular-api/fastify-oidc": {
      "injected": true
    }
  }
}
